# =========================================================================
# Dowon Law — Environment variables template
# Copy to .env.local for local dev. Never commit secrets.
# Use this same list when filling Vercel project settings → Environment Variables.
# =========================================================================

# --- AI Providers --------------------------------------------------------
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Supabase ------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Site ----------------------------------------------------------------
# Set to production URL on Vercel (e.g. https://www.dowonlaw.com).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Admin ---------------------------------------------------------------
# Comma-separated email allowlist for /admin access.
ADMIN_EMAIL_WHITELIST=

# --- Cron ----------------------------------------------------------------
# Bearer token for /api/cron/*. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
# Vercel Cron automatically uses this as the Authorization header.
CRON_SECRET=

# --- Notifications -------------------------------------------------------
# When blank, lib/notifications.ts uses a console.log stub (dev-safe).
RESEND_API_KEY=
SLACK_WEBHOOK_URL=
NOTIFY_EMAIL=dowonlaw@dowonlaw.com
NOTIFY_FROM="법무법인 도원 웹 <noreply@dowonlaw.com>"

# --- Medical AI safety ---------------------------------------------------
# Set to "true" to block external API calls on /api/ai/medical-analyze
# (PRD §6.2 AI #4 closed-network mode).
DOWON_DISABLE_EXTERNAL_AI=false

# --- Rate limiting (Upstash Redis) ---------------------------------------
# Both must be set for production AI endpoint protection. When blank,
# lib/ai/rate-limit.ts becomes a no-op (dev-safe).
# Get from console.upstash.com → Create database → REST API tab.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Error monitoring (Sentry) -------------------------------------------
# DSN is safe to expose; AUTH_TOKEN/ORG/PROJECT are only needed at build
# time for source map upload (set on Vercel, not required locally).
# When DSN is blank, Sentry init is a no-op.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# --- Optional integrations (Phase 4) -------------------------------------
SANITY_PROJECT_ID=
SANITY_DATASET=
# NEXT_PUBLIC_ prefix is required — the key is read by client-side JS.
NEXT_PUBLIC_POSTHOG_KEY=
# Region host. Defaults to us.i.posthog.com. EU users: https://eu.i.posthog.com
NEXT_PUBLIC_POSTHOG_HOST=

# Naver Maps (Naver Cloud Platform) — when set, /about/contact embeds a
# real interactive Naver Map; otherwise falls back to a Google Maps iframe.
# Free; ~5-minute setup at https://www.ncloud.com → Console → AI·Application
# Service → Maps → Application 등록. Register your domain(s) as Web Service
# URL (localhost:3000 for dev, www.dowonlaw.com for prod).
NEXT_PUBLIC_NAVER_MAP_CLIENT_ID=
